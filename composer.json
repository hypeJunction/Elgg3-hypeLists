{
    "name": "hypejunction/hypelists",
    "version": "4.0.0",
    "type": "elgg-plugin",
    "description": "AJAX lists for Elgg",
    "homepage": "http://hypejunction.com/",
    "keywords": [
        "elgg",
        "plugin",
        "hypejunction",
        "hypelist",
        "lists",
        "ajax"
    ],
    "license": "proprietary",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "info@hypejunction.com"
        }
    ],
    "extra": {
        "installer-name": "hypeLists",
        "elgg-plugin": {
            "id": "hypelists"
        }
    },
    "require": {
        "php": ">=7.4",
        "composer/installers": "^2.0",
        "elgg/elgg": "^4.0"
    },
    "autoload": {
        "psr-0": {
            "": "classes/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
