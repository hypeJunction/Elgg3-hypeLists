{
	"name": "hypejunction/hypelists",
	"version": "5.1.3",
	"type": "elgg-plugin",
	"description": "AJAX lists for Elgg",
	"homepage": "https://github.com/hypeJunction/Elgg3-hypeLists",
	"keywords": [
		"elgg",
		"plugin",
		"hypejunction",
		"hypelist",
		"lists",
		"ajax"
	],
	"license": "proprietary",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "ismayil.khayredinov@gmail.com"
		}
	],
	"extra": {
		"installer-name": "hypelists",
		"elgg-plugin": {
			"id": "hypelists"
		}
	},
	"require": {
		"php": ">=8.2",
		"composer/installers": "^2.0",
		"elgg/elgg": "^5.0"
	},
	"autoload": {
		"psr-0": {
			"": "classes/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
